# Runtime
V3_ONCE=false
V3_DEBUG=false
V3_HEARTBEAT_INTERVAL_SECONDS=10
V3_SILENT_WATCHDOG_SECONDS=60

# Live Switch & Stake
V3_ENABLE_LIVE_TRADING=false
V3_STAKE_USD=1

# Entry Range/Gate
V3_PRICE_RANGE_MIN=0.65
V3_PRICE_RANGE_MAX=0.95
V3_ENABLE_ENTRY_PRICE_GATE=true
V3_ENTRY_SLIPPAGE_PERCENT_BUY=1.5
V3_ENABLE_FALLBACK_GTC_LIMIT=false
V3_ORDER_RETRY_INTERVAL_MS=1000
V3_ORDER_MAX_ATTEMPTS=2

# Window Timing
V3_CHECK_BEFORE_CLOSE_SECONDS=6
V3_RESOLVE_DELAY_SECONDS=2
V3_IDLE_POLL_INTERVAL_MS=1000
V3_MARKET_POLL_INTERVAL_MS=500
V3_MARKET_LOOKUP_MAX_WAIT_MS=12000

# Risk Guards
V3_LOSS_COOLDOWN_MINUTES=0
V3_TOTAL_LOSS_TRADES=0

# Endpoints
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
BINANCE_BASE_URL=https://data-api.binance.vision/api/v3

# Live Price Source
LIVE_PRICE_SOURCE=CHAINLINK_PUBLIC
CHAINLINK_BTC_USD_FEED_ADDRESS=0xc907E116054Ad103354f2D350FD2514433D57F6f
LIVE_PRICE_MAX_STALENESS_MS=300000

# Polymarket Credentials
PRIVATE_KEY=
POLYMARKET_PRIVATE_KEY=
FUNDER_ADDRESS=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_BALANCE_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=2
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Settlement / Redeem
ENABLE_ONCHAIN_AUTO_CLAIM=true
SETTLEMENT_TX_MODE=RELAYER_SAFE
RELAYER_BASE_URL=https://relayer-v2.polymarket.com
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
RELAYER_REQUEST_TIMEOUT_MS=30000
RELAYER_POLL_INTERVAL_MS=2000
RELAYER_MAX_POLLS=120
RELAYER_ALLOW_FALLBACK_TO_DIRECT=true
SETTLEMENT_MAX_ATTEMPTS=3
SETTLEMENT_RETRY_DELAY_MS=5000
ENABLE_GAMMA_RESOLUTION_FALLBACK=true

POLYGON_RPC_URL=https://polygon.publicnode.com
CTF_CONTRACT=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
USDC_E=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174

REDEEM_TX_CONFIRM_TIMEOUT_MS=120000
REDEEM_GAS_LIMIT_MULTIPLIER=1.3
REDEEM_MIN_GAS_LIMIT=300000
REDEEM_MAX_FEE_PER_GAS_GWEI=100
REDEEM_MAX_PRIORITY_FEE_PER_GAS_GWEI=30
REDEEM_INTERNAL_MAX_ATTEMPTS=3
REDEEM_INTERNAL_RETRY_BASE_DELAY_MS=2000
REDEEM_INTERNAL_RETRY_BACKOFF_MULTIPLIER=2

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Output Files
V3_OUTPUT_FILE=result.jsonl
V3_TRADES_OUTPUT_FILE=trades.v3.jsonl
